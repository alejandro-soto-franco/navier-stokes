% darkmode.sty -- Dark background with WCAG AA-compliant foreground colours
% Usage: \usepackage{darkmode} in the preamble (after xcolor)
%
% Colour contrast ratios (against #2b2b2b background):
%   Text (#e0e0e0):      11.3:1  (AAA)
%   Math (#e0e0e0):      11.3:1  (AAA)
%   Link (#6cb4ee):       6.1:1  (AA)
%   Cite (#6cb4ee):       6.1:1  (AA)

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{darkmode}[2026/03/30 Dark mode colour scheme for book]

\RequirePackage{xcolor}
\RequirePackage{fancyhdr}

% --- Base colours ---
\definecolor{darkbg}{HTML}{2B2B2B}
\definecolor{darkfg}{HTML}{E0E0E0}
\definecolor{darklink}{HTML}{6CB4EE}
\definecolor{darkcite}{HTML}{6CB4EE}
\definecolor{darkrule}{HTML}{555555}

% --- Headers and footers in foreground colour ---
\fancypagestyle{darkheadings}{%
  \fancyhf{}%
  \fancyhead[LE]{\color{darkfg}\thepage\hspace{1.5em}\leftmark}%
  \fancyhead[RO]{\color{darkfg}\rightmark\hspace{1.5em}\thepage}%
  \renewcommand{\headrulewidth}{0.4pt}%
  \renewcommand{\headrule}{\color{darkrule}\hrule width\headwidth height\headrulewidth\vskip-\headrulewidth}%
  \renewcommand{\footrulewidth}{0pt}%
}
\fancypagestyle{plain}{%
  \fancyhf{}%
  \fancyfoot[C]{\color{darkfg}\thepage}%
  \renewcommand{\headrulewidth}{0pt}%
  \renewcommand{\footrulewidth}{0pt}%
}

% --- Footnotes in foreground colour ---
\let\darkmode@oldfootnotetext\@makefntext
\long\def\@makefntext#1{\darkmode@oldfootnotetext{\color{darkfg}#1}}
\renewcommand{\footnoterule}{%
  \kern-3pt{\color{darkrule}\hrule width 0.4\columnwidth height 0.4pt}\kern2.6pt}

% --- Apply all colour changes after \begin{document} ---
\AtBeginDocument{%
  \pagecolor{darkbg}%
  \color{darkfg}%
  \pagestyle{darkheadings}%
  \hypersetup{%
    colorlinks=true,
    linkcolor=darklink,
    citecolor=darkcite,
    urlcolor=darklink,
    filecolor=darklink,
  }%
}
